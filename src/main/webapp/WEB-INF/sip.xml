<?xml version="1.0" encoding="UTF-8"?>
<sip-app xmlns="http://www.jcp.org/xml/ns/sipservlet"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://www.jcp.org/xml/ns/sipservlet http://www.jcp.org/xml/ns/sipservlet/sip-app_1_1.xsd"
         version="1.1">
    <app-name>SipHttpPushGatewayApplication</app-name>
    <servlet>
        <servlet-name>PushNotificationServlet</servlet-name>
        <servlet-class>com.example.sip.PushNotificationServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>PushNotificationServlet</servlet-name>
        <pattern>
            <equal>
                <var>request.method</var>
                <value>INVITE</value>
            </equal>
        </pattern>
    </servlet-mapping>
</sip-app>
